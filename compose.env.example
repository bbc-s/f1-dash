# Stack versioning
STACK_VERSION=4.0.16
F1_DASH_IMAGE_TAG=latest
PORTAINER_TAG=2.27.2

# Bindings for localhost-only profile
WEB_PORT=3000
REALTIME_PORT=4000
API_PORT=4010
PORTAINER_PORT=9000
ARCHIVE_PORT=4020
ARCHIVE_RETENTION_DAYS=14
ARCHIVE_AUTO_RECORD=false
ARCHIVE_STORAGE_PATH_HOST=./data/archive

# Optional LAN profile
LAN_BIND_IP=192.168.1.50

# Rust logs
RUST_LOG_LEVEL=info


